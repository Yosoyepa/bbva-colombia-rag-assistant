# ─── Configuración externalizada (bonus) ────────────────────────────────────
# Copiar a `.env` y rellenar. NUNCA commitear `.env` (está en .gitignore).

# ── Proveedor LLM (multi-proveedor seleccionable) ──
# Uno de: anthropic | google | bedrock | ollama
MODEL_PROVIDER=google
LLM_MODEL=gemini-1.5-flash
# Orden de fallback (Chain of Responsibility + Circuit Breaker)
PROVIDER_FALLBACK_ORDER=google,anthropic,ollama

# Modelos por proveedor (evita enviar un nombre de Gemini a Claude/Ollama en fallback)
GOOGLE_MODEL=gemini-1.5-flash
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OLLAMA_MODEL=llama3.1:8b

# Claves por proveedor (rellenar solo las que uses)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
OLLAMA_HOST=http://localhost:11434

# ── Embeddings (local, CPU) ──
# La dimensión DEBE coincidir con VECTOR(N) en schema.sql (por defecto 384).
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# ── RAG ──
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Memoria conversacional (CU-03) ──
N_HISTORY_MESSAGES=6

# ── Scraping (CU-01) ──
SCRAPE_BASE_URL=https://www.bbva.com.co/

# ── PostgreSQL + pgvector ──
PG_HOST=localhost
PG_PORT=5432
PG_USER=bbva
PG_PASSWORD=bbva
PG_DATABASE=bbva_rag
